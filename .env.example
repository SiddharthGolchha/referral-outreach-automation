# Copy this file to ".env" and fill in your real values. Never commit ".env".

# Gmail address you're sending from
GMAIL_ADDRESS=your_email@gmail.com

# Gmail App Password (NOT your normal Gmail password)
# Generate one at: https://myaccount.google.com/apppasswords
# (Requires 2-Step Verification to be enabled on your Google account)
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Your details, used to personalize the templates
MY_NAME=<Name>
MY_PHONE=<Number>
MY_EMAIL=<Email>
MY_LINKEDIN=https://linkedin.com/in/your-profile-here

# Path to your resume, relative to this folder
RESUME_PATH=resume/fileName

# How many days to wait before sending a follow-up
FOLLOWUP_WAIT_DAYS=2